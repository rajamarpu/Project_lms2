# Backend runtime
PORT=5001
JWT_SECRET="replace_with_a_strong_secret"
JWT_EXPIRES_IN="30d"
REFRESH_TOKEN_DAYS=30
GEMINI_API_KEY=""
CLIENT_URL="http://localhost:3000"
ADMIN_EMAIL="admin@gmail.com"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Admin"
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

# Database selection
# Set DATABASE_ENV=test when running test-specific scripts against DATABASE_URL_TEST.
# Prisma runtime will prefer DATABASE_URL_TEST when NODE_ENV=test.

# Local PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/lms_dev?schema=public"

# Supabase direct connection
# Use this for local development or production when the direct database host is reachable.
# DATABASE_URL_DIRECT="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Supabase pooler connection
# Use this if the direct host is blocked by your network or cloud provider.
# DATABASE_URL_POOLER="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true"

# Active runtime connection string
# For local development you can point DATABASE_URL to localhost.
# For Supabase deployments you can point DATABASE_URL to the direct host or the pooler URL.
DATABASE_URL="postgresql://postgres:[PASSWORD]@localhost:5432/lms_dev?schema=public"

# Separate test database
# DATABASE_URL_TEST="postgresql://postgres:[PASSWORD]@localhost:5432/lms_test?schema=public"

# Optional read replica
# DATABASE_URL_REPLICA="postgresql://username:password@host:5432/database?sslmode=require"
